<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Folia"
           Manufacturer="water2004"
           Version="$(var.ProductVersion)"
           Language="1033"
           UpgradeCode="BFEA4C2E-729A-4D77-9EA3-A8EA8B8C30F5"
           Scope="perUser"
           Compressed="yes">
    <SummaryInformation Description="Folia Markdown editor" Manufacturer="water2004" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Folia is already installed." />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="LOCALPROGRAMS" Name="Programs">
        <Component Id="LocalProgramsCleanupComponent" Guid="86CB1882-B330-49D7-964B-E4C5858EFA9B" Bitness="always64">
          <RemoveFolder Id="RemoveLocalProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Installer" Name="LocalProgramsFolder" Type="integer" Value="1" KeyPath="yes" />
        </Component>
        <Directory Id="INSTALLFOLDER" Name="Folia">
          <Component Id="InstallFolderCleanupComponent" Guid="DBAF6E84-02A9-4F03-967B-5F57CDA33652" Bitness="always64">
            <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Installer" Name="InstallFolder" Type="integer" Value="1" KeyPath="yes" />
          </Component>
          <Component Id="MarkdownFileAssociationComponent" Guid="15007EF1-9604-4FF6-BD0A-B793E1AF7D9D" Bitness="always64">
            <!-- Default Apps registration: advertises Folia without silently taking ownership. -->
            <RegistryValue Root="HKCU" Key="Software\RegisteredApplications" Name="Folia" Type="string"
                           Value="Software\water2004\Folia\Capabilities" KeyPath="yes" />
            <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Capabilities" Name="ApplicationName"
                           Type="string" Value="Folia" />
            <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Capabilities" Name="ApplicationDescription"
                           Type="string" Value="Folia Markdown editor" />
            <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Capabilities" Name="ApplicationIcon"
                           Type="string" Value="[INSTALLFOLDER]Folia.exe,0" />
            <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Capabilities\FileAssociations" Name=".md"
                           Type="string" Value="Folia.Markdown" />
            <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Capabilities\FileAssociations" Name=".markdown"
                           Type="string" Value="Folia.Markdown" />

            <!-- ProgID used by Open With and by the Default Apps picker. -->
            <RegistryValue Root="HKCU" Key="Software\Classes\Folia.Markdown"
                           Type="string" Value="Folia Markdown document" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Folia.Markdown" Name="FriendlyTypeName"
                           Type="string" Value="Folia Markdown document" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Folia.Markdown\DefaultIcon"
                           Type="string" Value="[INSTALLFOLDER]Folia.exe,0" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Folia.Markdown\shell\open\command"
                           Type="string" Value="&quot;[INSTALLFOLDER]Folia.exe&quot; &quot;%1&quot;" />
            <RegistryValue Root="HKCU" Key="Software\Classes\.md\OpenWithProgids" Name="Folia.Markdown"
                           Type="string" Value="" />
            <RegistryValue Root="HKCU" Key="Software\Classes\.markdown\OpenWithProgids" Name="Folia.Markdown"
                           Type="string" Value="" />

            <!-- Explicit Applications entry keeps Folia visible in the classic Open With dialog. -->
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\Folia.exe" Name="FriendlyAppName"
                           Type="string" Value="Folia" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\Folia.exe\DefaultIcon"
                           Type="string" Value="[INSTALLFOLDER]Folia.exe,0" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\Folia.exe\SupportedTypes" Name=".md"
                           Type="string" Value="" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\Folia.exe\SupportedTypes" Name=".markdown"
                           Type="string" Value="" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\Folia.exe\shell\open\command"
                           Type="string" Value="&quot;[INSTALLFOLDER]Folia.exe&quot; &quot;%1&quot;" />
          </Component>
        </Directory>
      </Directory>
      <Directory Id="FOLIADATADIR" Name="Folia">
        <Component Id="DataFolderCleanupComponent" Guid="A21E1701-41CE-4D84-9503-D13948007431" Bitness="always64">
          <RemoveFolder Id="RemoveDataFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Installer" Name="DataFolder" Type="integer" Value="1" KeyPath="yes" />
        </Component>
        <Directory Id="ASSETFOLDER" Name="Assets">
          <Component Id="AssetsFolderCleanupComponent" Guid="5FF0447F-7D13-4C98-97F5-C4EBB2C17B90" Bitness="always64">
            <RemoveFolder Id="RemoveAssetsFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\water2004\Folia\Installer" Name="AssetsFolder" Type="integer" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="FoliaProgramMenu" Name="Folia">
        <Component Id="StartMenuShortcutComponent" Guid="*" Bitness="always64">
          <Shortcut Id="StartMenuShortcut"
                    Name="Folia"
                    Description="Folia Markdown editor"
                    Target="[INSTALLFOLDER]Folia.exe"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="FoliaProductIcon" />
          <RemoveFolder Id="RemoveFoliaProgramMenu" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\water2004\Folia\Installer"
                         Name="StartMenuShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="FoliaFeature" Title="Folia" Level="1">
      <ComponentGroupRef Id="ProgramPayload" />
      <ComponentGroupRef Id="AssetPayload" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="LocalProgramsCleanupComponent" />
      <ComponentRef Id="InstallFolderCleanupComponent" />
      <ComponentRef Id="MarkdownFileAssociationComponent" />
      <ComponentRef Id="DataFolderCleanupComponent" />
      <ComponentRef Id="AssetsFolderCleanupComponent" />
    </Feature>

    <Icon Id="FoliaProductIcon" SourceFile="$(var.ProductIcon)" />
    <Property Id="ARPPRODUCTICON" Value="FoliaProductIcon" />
    <Property Id="ARPCONTACT" Value="water2004" />

    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
  </Package>
</Wix>
