<Window
    x:Class="ElMd.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ElMd"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="el-md - Native Markdown Editor">
    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="280,*">
        <CommandBar Grid.Row="0" Grid.ColumnSpan="2" DefaultLabelPosition="Right">
            <AppBarButton x:Name="OpenButton" Icon="OpenFile" Label="Open"/>
            <AppBarButton x:Name="SaveButton" Icon="Save" Label="Save"/>
            <AppBarSeparator/>
            <AppBarButton x:Name="BoldButton" Icon="Bold" Label="Bold"/>
            <AppBarButton x:Name="ItalicButton" Icon="Italic" Label="Italic"/>
        </CommandBar>

        <Border Grid.Row="1" Grid.Column="0" Background="#F3F5F8" BorderBrush="#D7DCE3" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*" Padding="16,14">
                <TextBlock Text="Outline" FontSize="15" FontWeight="SemiBold" Foreground="#273142" Margin="0,0,0,10"/>
                <ListView x:Name="OutlineList" Grid.Row="1" SelectionMode="Single" Background="Transparent"/>
            </Grid>
        </Border>

        <SwapChainPanel x:Name="EditorSurface" Grid.Row="1" Grid.Column="1"/>

        <TextBlock x:Name="StatusText" Grid.Row="2" Grid.ColumnSpan="2" Padding="12,6" Text="Ready"/>
    </Grid>
</Window>
