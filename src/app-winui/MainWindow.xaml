<Window
    x:Class="ElMd.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ElMd"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="el-md - Native Markdown Editor">
    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="280,*">
        <CommandBar Grid.Row="0" Grid.ColumnSpan="2" DefaultLabelPosition="Right">
            <AppBarButton x:Name="OpenButton" Icon="OpenFile" Label="Open"/>
            <AppBarButton x:Name="SaveButton" Icon="Save" Label="Save"/>
            <AppBarSeparator/>
            <AppBarButton x:Name="BoldButton" Icon="Bold" Label="Bold"/>
            <AppBarButton x:Name="ItalicButton" Icon="Italic" Label="Italic"/>
        </CommandBar>

        <NavigationView Grid.Row="1" Grid.Column="0" PaneDisplayMode="LeftMinimal" IsBackButtonVisible="Collapsed" IsSettingsVisible="False">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Outline" Icon="List"/>
                <NavigationViewItem Content="Diagnostics" Icon="ReportHacked"/>
                <NavigationViewItem Content="Assets" Icon="Pictures"/>
                <NavigationViewItem Content="Search" Icon="Find"/>
            </NavigationView.MenuItems>
        </NavigationView>

        <SwapChainPanel x:Name="EditorSurface" Grid.Row="1" Grid.Column="1"/>

        <TextBlock x:Name="StatusText" Grid.Row="2" Grid.ColumnSpan="2" Padding="12,6" Text="Ready"/>
    </Grid>
</Window>
