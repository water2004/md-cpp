<Window
    x:Class="Folia.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Folia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Folia">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid x:Name="Root" RowDefinitions="40,Auto,Auto,*,Auto">
        <Grid.Resources>
            <SolidColorBrush x:Key="FoliaShellBackgroundBrush" Color="#121419"/>
            <SolidColorBrush x:Key="FoliaShellLayerBrush" Color="#191C23"/>
            <SolidColorBrush x:Key="FoliaShellBorderBrush" Color="#343A46"/>
            <SolidColorBrush x:Key="FoliaShellForegroundBrush" Color="#E4E8F0"/>
            <SolidColorBrush x:Key="FoliaShellMutedForegroundBrush" Color="#8B95AA"/>
            <SolidColorBrush x:Key="FoliaShellAccentBrush" Color="#7AA2F7"/>
            <FontFamily x:Key="FoliaUiFontFamily">Segoe UI Variable Text</FontFamily>
            <FontFamily x:Key="FoliaMonoFontFamily">Cascadia Mono</FontFamily>
            <x:Double x:Key="FoliaUiFontSize">14</x:Double>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{ThemeResource FoliaUiFontFamily}"/>
                <Setter Property="FontSize" Value="{ThemeResource FoliaUiFontSize}"/>
                <Setter Property="Foreground" Value="{ThemeResource FoliaShellForegroundBrush}"/>
            </Style>
        </Grid.Resources>
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="12,0,144,0"
            Background="{ThemeResource FoliaShellBackgroundBrush}"
            ColumnDefinitions="Auto,Auto,*">
            <TextBlock
                x:Name="ApplicationNameText"
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="Folia"/>
            <Border
                Grid.Column="1"
                Width="1"
                Height="14"
                Margin="12,0"
                VerticalAlignment="Center"
                Background="{ThemeResource FoliaShellBorderBrush}"/>
            <TextBlock
                x:Name="TitleDocumentText"
                Grid.Column="2"
                VerticalAlignment="Center"
                Foreground="{ThemeResource FoliaShellMutedForegroundBrush}"
                Text="Untitled.md"
                TextTrimming="CharacterEllipsis"/>
        </Grid>

        <CommandBar
            x:Name="ShellCommandBar"
            Grid.Row="1"
            Padding="4,0"
            Background="{ThemeResource FoliaShellLayerBrush}"
            BorderBrush="{ThemeResource FoliaShellBorderBrush}"
            BorderThickness="0,0,0,1"
            DefaultLabelPosition="Right"
            IsDynamicOverflowEnabled="True">
            <CommandBar.Content>
                <AppBarButton
                    x:Name="SidebarToggleButton"
                    Icon="GlobalNavigationButton"
                    Label="Sidebar"
                    LabelPosition="Collapsed"
                    ToolTipService.ToolTip="Toggle outline"/>
            </CommandBar.Content>
            <AppBarButton x:Name="OpenButton" Icon="OpenFile" Label="Open" ToolTipService.ToolTip="Open a Markdown document"/>
            <AppBarButton x:Name="SaveButton" Icon="Save" Label="Save" ToolTipService.ToolTip="Save the current document"/>
            <AppBarButton x:Name="ExportPdfButton" Icon="Print" Label="PDF" ToolTipService.ToolTip="Export with Windows PDF printing"/>
            <AppBarSeparator x:Name="FileFormatSeparator"/>
            <AppBarButton x:Name="BoldButton" Icon="Bold" Label="Bold" ToolTipService.ToolTip="Bold"/>
            <AppBarButton x:Name="ItalicButton" Icon="Italic" Label="Italic" ToolTipService.ToolTip="Italic"/>
            <AppBarButton x:Name="StrikeButton" Label="Strike" ToolTipService.ToolTip="Strikethrough"/>
            <AppBarButton x:Name="InlineCodeButton" Label="Inline Code" ToolTipService.ToolTip="Inline code"/>
            <AppBarSeparator x:Name="InlineBlockSeparator"/>
            <AppBarButton x:Name="BlocksButton" Icon="Bullets" Label="Blocks" ToolTipService.ToolTip="Block structure">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutSubItem x:Name="HeadingMenuItem" Text="Heading">
                            <MenuFlyoutItem x:Name="Heading1Button" Text="Heading 1"/>
                            <MenuFlyoutItem x:Name="Heading2Button" Text="Heading 2"/>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutItem x:Name="QuoteButton" Text="Quote"/>
                        <MenuFlyoutSubItem x:Name="ListMenuItem" Text="List">
                            <MenuFlyoutItem x:Name="UnorderedListButton" Text="Bulleted list"/>
                            <MenuFlyoutItem x:Name="OrderedListButton" Text="Numbered list"/>
                            <MenuFlyoutItem x:Name="TaskListButton" Text="Task list"/>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="CodeBlockButton" Text="Code block"/>
                        <MenuFlyoutItem x:Name="BlockMathButton" Text="Math block"/>
                        <MenuFlyoutSubItem x:Name="CalloutMenuItem" Text="Callout">
                            <MenuFlyoutItem x:Name="CalloutNoteMenuItem" Text="Note"/>
                            <MenuFlyoutItem x:Name="CalloutTipMenuItem" Text="Tip"/>
                            <MenuFlyoutItem x:Name="CalloutWarningMenuItem" Text="Warning"/>
                        </MenuFlyoutSubItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton x:Name="InsertButton" Icon="Add" Label="Insert" ToolTipService.ToolTip="Insert content">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="TableButton" Text="Table"/>
                        <MenuFlyoutItem x:Name="InlineMathButton" Text="Inline math"/>
                        <MenuFlyoutItem x:Name="LinkButton" Text="Link"/>
                        <MenuFlyoutItem x:Name="ImageButton" Text="Image"/>
                        <MenuFlyoutItem x:Name="FootnoteButton" Text="Footnote"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="TocButton" Text="Table of contents"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarSeparator x:Name="SettingsSeparator"/>
            <AppBarToggleButton
                x:Name="SettingsButton"
                Icon="Setting"
                Label="Settings"
                LabelPosition="Collapsed"
                ToolTipService.ToolTip="Settings"/>
        </CommandBar>

        <Border
            x:Name="FindReplaceBar"
            Grid.Row="2"
            Padding="10,8"
            Background="{ThemeResource FoliaShellLayerBrush}"
            BorderBrush="{ThemeResource FoliaShellBorderBrush}"
            BorderThickness="0,0,0,1"
            Visibility="Collapsed">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBox
                        x:Name="FindQueryBox"
                        Width="320"
                        MinWidth="180"
                        PlaceholderText="Find"/>
                    <ToggleButton
                        x:Name="FindRegexButton"
                        MinWidth="36"
                        Content=".*"
                        FontFamily="{ThemeResource FoliaMonoFontFamily}"
                        ToolTipService.ToolTip="Regular expression"/>
                    <ToggleButton
                        x:Name="FindCaseButton"
                        MinWidth="36"
                        Content="Aa"
                        ToolTipService.ToolTip="Match case"/>
                    <TextBlock
                        x:Name="FindMatchCountText"
                        MinWidth="72"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource FoliaShellMutedForegroundBrush}"
                        Text="0 results"/>
                    <Button x:Name="FindPreviousButton" MinWidth="36" Content="↑" ToolTipService.ToolTip="Previous match"/>
                    <Button x:Name="FindNextButton" MinWidth="36" Content="↓" ToolTipService.ToolTip="Next match"/>
                </StackPanel>
                <Button
                    x:Name="CloseFindButton"
                    Grid.Column="1"
                    MinWidth="36"
                    Content="&#xE711;"
                    FontFamily="Segoe Fluent Icons"
                    ToolTipService.ToolTip="Close"/>
                <StackPanel
                    x:Name="ReplaceControls"
                    Grid.Row="1"
                    Margin="0,6,0,0"
                    Orientation="Horizontal"
                    Spacing="6"
                    Visibility="Collapsed">
                    <TextBox
                        x:Name="ReplaceTextBox"
                        Width="320"
                        MinWidth="180"
                        PlaceholderText="Replace"/>
                    <Button x:Name="ReplaceCurrentButton" Content="Replace"/>
                    <Button x:Name="ReplaceAllButton" Content="Replace all"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="WorkspaceHost" Grid.Row="3">
            <NavigationView
                x:Name="DocumentNavigation"
                AlwaysShowHeader="False"
                CompactPaneLength="0"
                IsBackButtonVisible="Collapsed"
                IsPaneOpen="True"
                IsPaneToggleButtonVisible="False"
                IsSettingsVisible="False"
                IsTitleBarAutoPaddingEnabled="False"
                OpenPaneLength="280"
                PaneDisplayMode="Left">
                <NavigationView.PaneCustomContent>
                    <Grid
                        MaxHeight="{Binding ActualHeight, ElementName=WorkspaceHost}"
                        Padding="8,8,8,8"
                        RowDefinitions="Auto,*">
                        <TextBlock
                            x:Name="OutlineHeadingText"
                            Margin="8,4,8,8"
                            FontWeight="SemiBold"
                            Text="Outline"/>
                        <ListView
                            x:Name="OutlineList"
                            Grid.Row="1"
                            Background="Transparent"
                            SelectionMode="Single"/>
                    </Grid>
                </NavigationView.PaneCustomContent>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="EditorScrollBarColumn" Width="16"/>
                    </Grid.ColumnDefinitions>
                    <SwapChainPanel x:Name="EditorSurface" Grid.Column="0" KeyboardAcceleratorPlacementMode="Hidden">
                        <SwapChainPanel.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Name="CutMenuItem" Text="Cut"/>
                                <MenuFlyoutItem x:Name="CopyMenuItem" Text="Copy"/>
                                <MenuFlyoutItem x:Name="PasteMenuItem" Text="Paste"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem x:Name="SelectAllMenuItem" Text="Select All"/>
                            </MenuFlyout>
                        </SwapChainPanel.ContextFlyout>
                    </SwapChainPanel>
                    <ScrollBar
                        x:Name="EditorScrollBar"
                        Grid.Column="1"
                        Width="16"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource FoliaShellLayerBrush}"
                        IndicatorMode="MouseIndicator"
                        IsTabStop="False"
                        Minimum="0"
                        Orientation="Vertical"
                        SmallChange="48"
                        UseLayoutRounding="False"/>
                </Grid>
            </NavigationView>
            <Canvas
                x:Name="EditorOverlay"
                IsHitTestVisible="False"
                Canvas.ZIndex="20">
                <Border
                    x:Name="LatexSuggestionPopup"
                    Width="430"
                    MaxHeight="330"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="Collapsed">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Grid
                            Padding="12,9"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            ColumnDefinitions="Auto,*,Auto">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Cambria Math"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Text="∑"/>
                            <TextBlock
                                Grid.Column="1"
                                Margin="9,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="LaTeX"/>
                            <TextBlock
                                x:Name="LatexSuggestionPrefix"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource FoliaMonoFontFamily}"
                                Foreground="{ThemeResource FoliaShellMutedForegroundBrush}"
                                Text="\"/>
                        </Grid>
                        <ListView
                            x:Name="LatexSuggestionList"
                            Grid.Row="1"
                            MaxHeight="250"
                            HorizontalContentAlignment="Stretch"
                            SelectionMode="Single"
                            SingleSelectionFollowsFocus="False"/>
                        <Border
                            Grid.Row="2"
                            Padding="12,6"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock
                                x:Name="LatexSuggestionHint"
                                FontSize="11"
                                Foreground="{ThemeResource FoliaShellMutedForegroundBrush}"
                                Text="↑↓  Navigate     Tab / Enter  Insert     Esc  Close"/>
                        </Border>
                    </Grid>
                </Border>
            </Canvas>
            <Grid x:Name="SettingsViewHost" Visibility="Collapsed"/>
        </Grid>

        <Grid
            x:Name="StatusBar"
            Grid.Row="4"
            MinHeight="32"
            Padding="10,3,8,3"
            Background="{ThemeResource FoliaShellLayerBrush}"
            BorderBrush="{ThemeResource FoliaShellBorderBrush}"
            BorderThickness="0,1,0,0"
            ColumnDefinitions="*,Auto,Auto,Auto">
            <TextBlock
                x:Name="StatusText"
                VerticalAlignment="Center"
                Foreground="{ThemeResource FoliaShellMutedForegroundBrush}"
                Text="Ready"
                TextTrimming="CharacterEllipsis"/>
            <ProgressBar
                x:Name="OperationProgressBar"
                Grid.Column="1"
                Width="160"
                Margin="12,0"
                VerticalAlignment="Center"
                Foreground="{ThemeResource FoliaShellAccentBrush}"
                IsIndeterminate="True"
                IsTabStop="False"
                Maximum="100"
                Minimum="0"
                Visibility="Collapsed"/>
            <Button
                x:Name="CancelOperationButton"
                Grid.Column="2"
                Width="16"
                Height="16"
                MinWidth="16"
                MinHeight="16"
                Margin="0,0,8,0"
                Padding="0"
                VerticalAlignment="Center"
                Background="Black"
                BorderThickness="0"
                CornerRadius="8"
                HorizontalContentAlignment="Center"
                IsTabStop="False"
                ToolTipService.ToolTip="Cancel operation"
                VerticalContentAlignment="Center"
                Visibility="Collapsed">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="8"
                    Foreground="White"
                    Glyph="&#xE711;"/>
            </Button>
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="14">
                <TextBlock
                    x:Name="DocumentNameText"
                    MaxWidth="320"
                    VerticalAlignment="Center"
                    Text="Untitled.md"
                    TextTrimming="CharacterEllipsis"/>
                <TextBlock
                    x:Name="CharacterCountText"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource FoliaShellMutedForegroundBrush}"
                    Text="0 characters"/>
                <TextBlock
                    x:Name="RevisionText"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource FoliaShellMutedForegroundBrush}"
                    Text="Revision 0"/>
                <ToggleButton
                    x:Name="SourceModeButton"
                    MinWidth="36"
                    Padding="8,2"
                    FontFamily="{ThemeResource FoliaMonoFontFamily}"
                    Content="&lt;/&gt;"
                    ToolTipService.ToolTip="Source mode"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
