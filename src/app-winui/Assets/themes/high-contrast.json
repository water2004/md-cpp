{
  "schemaVersion": 1,
  "id": "elmd.high-contrast",
  "name": "el-md High Contrast",
  "variant": "high-contrast",
  "typography": {
    "body": { "family": "Microsoft YaHei UI", "size": 18, "lineHeight": 29, "weight": 400, "italic": false },
    "heading1": { "family": "Microsoft YaHei UI", "size": 38, "lineHeight": 46, "weight": 600, "italic": false },
    "heading2": { "family": "Microsoft YaHei UI", "size": 30, "lineHeight": 37, "weight": 600, "italic": false },
    "heading3": { "family": "Microsoft YaHei UI", "size": 24, "lineHeight": 30, "weight": 600, "italic": false },
    "code": { "family": "Cascadia Code", "size": 15, "lineHeight": 24, "weight": 400, "italic": false },
    "ui": { "family": "Segoe UI Variable Text", "size": 14, "lineHeight": 20, "weight": 400, "italic": false },
    "uiMonospace": { "family": "Cascadia Mono", "size": 14, "lineHeight": 20, "weight": 400, "italic": false }
  },
  "colors": {
    "background": "#000000", "foreground": "#FFFFFF", "mutedForeground": "#DCDCDC", "accent": "#00FFFF",
    "heading": "#FFFF00", "strong": "#FFFFFF", "emphasis": "#FFA500",
    "inlineCodeBackground": "#282828", "inlineCodeForeground": "#FFFF00",
    "codeBlockBackground": "#141414", "codeBlockForeground": "#FFFFFF",
    "blockquoteBorder": "#00FFFF", "blockquoteBackground": "#141E28", "nestedQuoteBackground": "#0A0F14",
    "link": "#00FFFF", "imageBorder": "#FFFFFF", "selectionBackground": "#FFFF00", "selectionForeground": "#000000",
    "caret": "#FFFFFF", "marker": "#DCDCDC", "mathBackground": "#1E1E1E", "mathForeground": "#FFFFFF",
    "calloutNoteBackground": "#00003C", "calloutNoteBorder": "#00FFFF",
    "calloutWarningBackground": "#3C1E00", "calloutWarningBorder": "#FFA500",
    "calloutTipBackground": "#002800", "calloutTipBorder": "#00FF00",
    "calloutImportantBackground": "#28003C", "calloutImportantBorder": "#FF00FF",
    "calloutCautionBackground": "#3C0000", "calloutCautionBorder": "#FF0000",
    "frontmatterBackground": "#14141E", "frontmatterForeground": "#FFFFFF",
    "tableBorder": "#FFFFFF", "tableHeaderBackground": "#3C3C3C", "lineNumber": "#DCDCDC",
    "strikethrough": "#FFFFFF", "unsupportedBackground": "#3C2800", "unsupportedForeground": "#FFC800",
    "shellBackground": "#000000", "shellLayerBackground": "#141414", "shellBorder": "#FFFFFF",
    "shellForeground": "#FFFFFF", "shellMutedForeground": "#DCDCDC", "shellAccent": "#00FFFF",
