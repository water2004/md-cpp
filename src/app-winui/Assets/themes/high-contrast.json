    "quoteMargin": 8, "quotePaddingVertical": 6, "quotePaddingLeft": 18, "quotePaddingRight": 8, "quoteBorderWidth": 3,
    "mathMargin": 12, "mathPaddingVertical": 8, "mathPaddingHorizontal": 12,
    "tableMargin": 8, "imageMargin": 12, "tocMargin": 12, "tocPaddingLeft": 8, "tocBorderWidth": 2,
    "calloutMargin": 8, "calloutPaddingVertical": 8, "calloutPaddingLeft": 16, "calloutBorderWidth": 4,
    "frontmatterMarginBottom": 12, "frontmatterPaddingVertical": 8, "frontmatterPaddingHorizontal": 12,
    "footnoteMargin": 8, "footnotePaddingVertical": 8, "footnotePaddingHorizontal": 12,
    "unsupportedMargin": 8, "unsupportedPaddingVertical": 4, "unsupportedPaddingLeft": 12, "extensionMargin": 4,
